{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "db:seed": "bun run src/server/db/seed.ts",
    "simulate:camera": "bun run scripts/simulate-camera.ts",
    "simulate:samples": "bun run scripts/post-samples.ts",
    "test": "bun test"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "echarts": "^6.0.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
